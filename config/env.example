# Copy to .env and export these values into your shell as needed.

# Optional common defaults
SPLUNK_TARGET=default

# Example target-specific values used by config/splunk_targets.yaml
SPLUNK_DEFAULT_BASE_URL=https://localhost:8089
SPLUNK_DEFAULT_USERNAME=admin
SPLUNK_DEFAULT_PASSWORD=changeme
SPLUNK_DEFAULT_TOKEN=
SPLUNK_DEFAULT_VERIFY_SSL=false
SPLUNK_DEFAULT_NAMESPACE=search

# Optional per-target token examples
# SPLUNK_PROD_TOKEN=
# SPLUNK_NONPROD_TOKEN=
